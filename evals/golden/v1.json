{"description": "FDAgent v1 golden eval set for /ask routing and retrieval recall@k.",
  "version": "v1",
  "cases": [
    {
      "id": "control-meta-who-are-you",
      "kind": "ask",
      "question": "who you are?",
      "assert": {
        "route": "chitchat_meta",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-out-of-domain-joke",
      "kind": "ask",
      "question": "Tell me a joke.",
      "assert": {
        "route": "out_of_domain",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-zh-meta-ask",
      "kind": "ask",
      "question": "你可以做什么？",
      "assert": {
        "route": "chitchat_meta",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-zh-out-of-domain-ask",
      "kind": "ask",
      "question": "今天天气怎么样？",
      "assert": {
        "route": "out_of_domain",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-zh-superpotent-semantic",
      "kind": "ask",
      "question": "给我看几个因为药效太强被召回的药品。",
      "assert": {
        "route": "semantic",
        "intents": ["sample"],
        "data_kinds": ["retrieval"],
        "no_ilike": true,
        "semantic_query_contains_any": ["superpotent", "strong", "potent", "assay"]
      }
    },
    {
      "id": "numeric-class-i-count",
      "kind": "ask",
      "question": "How many Class I drug recalls have there been?",
      "assert": {
        "route": "sql",
        "intents": ["count_total"],
        "data_kinds": ["scalar"],
        "value_equals": 1729,
        "no_ilike": true
      }
    },
    {
      "id": "numeric-class-i-by-firm",
      "kind": "ask",
      "question": "Which firms had the most Class I recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_by"],
        "data_kinds": ["distribution"],
        "top_items": [
          {"value": "King Bio Inc.", "count": 465}
        ],
        "no_ilike": true
      }
    },
    {
      "id": "fuzzy-sterility-routing",
      "kind": "ask",
      "question": "Show me a few sterility-related recalls.",
      "assert": {
        "route": "semantic",
        "intents": ["sample"],
        "data_kinds": ["retrieval"],
        "no_ilike": true,
        "semantic_query_contains_any": ["sterility", "sterile"]
      }
    },
    {
      "id": "fuzzy-superpotent-routing",
      "kind": "ask",
      "question": "Show recalls where pills were too strong.",
      "assert": {
        "route": "semantic",
        "intents": ["sample"],
        "data_kinds": ["retrieval"],
        "no_ilike": true,
        "semantic_query_contains_any": ["strong", "superpotent", "potent"]
      }
    },
    {
      "id": "taxonomy-sterility-exact-count",
      "kind": "ask",
      "question": "How many sterility recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_total"],
        "data_kinds": ["scalar"],
        "no_ilike": true,
        "value_equals": 6308
      }
    },
    {
      "id": "taxonomy-reason-breakdown",
      "kind": "ask",
      "question": "What are the most common recall reason categories?",
      "assert": {
        "route": "sql",
        "intents": ["count_by_taxonomy"],
        "data_kinds": ["distribution"],
        "no_ilike": true,
        "top_items": [
          {"value": "sterility_assurance", "count": 6308}
        ]
      }
    },
    {
      "id": "taxonomy-sterility-by-firm",
      "kind": "ask",
      "question": "Which firms had the most sterility recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_by"],
        "data_kinds": ["distribution"],
        "no_ilike": true,
        "top_items": [
          {"value": "The Compounding Pharmacy of America", "count": 383}
        ]
      }
    },
    {
      "id": "control-empty-sample-guard",
      "kind": "ask",
      "question": "Show me recalls.",
      "assert": {
        "route": "ambiguous",
        "data_kinds": ["clarification"],
        "spec_empty": true
      }
    },
    {
      "id": "retrieval-glass-particles",
      "kind": "retrieval_recall",
      "query": "glass particles in drug vials",
      "field": "both",
      "k": 10,
      "expected_recall_numbers": ["D-0580-2026", "D-0412-2025", "D-0416-2025"],
      "min_recall_at_k": 0.34
    }
  ]
}
