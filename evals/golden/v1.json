{"description": "FDAgent v1 golden eval set for /ask routing and retrieval recall@k.",
  "version": "v1",
  "cases": [
    {
      "id": "control-meta-who-are-you",
      "kind": "ask",
      "question": "who you are?",
      "assert": {
        "route": "chitchat_meta",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-out-of-domain-joke",
      "kind": "ask",
      "question": "Tell me a joke.",
      "assert": {
        "route": "out_of_domain",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-out-of-domain-company-employees",
      "kind": "ask",
      "question": "Which companies have the most employees?",
      "assert": {
        "route": "out_of_domain",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-zh-meta-ask",
      "kind": "ask",
      "question": "你可以做什么？",
      "assert": {
        "route": "chitchat_meta",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-zh-out-of-domain-ask",
      "kind": "ask",
      "question": "今天天气怎么样？",
      "assert": {
        "route": "out_of_domain",
        "data_kinds": ["message"],
        "spec_empty": true
      }
    },
    {
      "id": "control-zh-superpotent-semantic",
      "kind": "ask",
      "question": "给我看几个因为药效太强被召回的药品。",
      "assert": {
        "route": "semantic",
        "intents": ["sample"],
        "data_kinds": ["retrieval"],
        "no_ilike": true,
        "semantic_query_contains_any": ["superpotent", "strong", "potent", "assay"]
      }
    },
    {
      "id": "numeric-class-i-count",
      "kind": "ask",
      "question": "How many Class I drug recalls have there been?",
      "assert": {
        "route": "sql",
        "intents": ["count_total"],
        "data_kinds": ["scalar"],
        "value_equals": 1729,
        "no_ilike": true
      }
    },
    {
      "id": "numeric-class-i-by-firm",
      "kind": "ask",
      "question": "Which firms had the most Class I recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_by"],
        "data_kinds": ["distribution"],
        "top_items": [
          {"value": "King Bio Inc.", "count": 465}
        ],
        "no_ilike": true
      }
    },
    {
      "id": "exposure-raw-firm-count-leaderboard",
      "kind": "ask",
      "question": "Which recalling firms have the most FDA drug recalls?",
      "assert": {
        "route": "sql",
        "intents": ["raw_firm_exposure"],
        "data_kinds": ["raw_firm_exposure"],
        "data_fields": {
          "metric": "recall_count",
          "formula_version": "raw_severity_v0",
          "scope": "raw_fda_recalling_firm"
        },
        "top_items": [
          {
            "rank": 1,
            "recalling_firm": "Aidapak Services, LLC",
            "total_recalls": 538,
            "class_i_recalls": 0,
            "class_ii_recalls": 538,
            "class_iii_recalls": 0,
            "exposure_score": 1076
          }
        ],
        "summary_contains_any": ["raw FDA `recalling_firm`", "not a safety verdict", "3 * Class I"],
        "no_ilike": true
      }
    },
    {
      "id": "exposure-severity-weighted-leaderboard",
      "kind": "ask",
      "question": "Rank firms by severity-weighted recalls.",
      "assert": {
        "route": "sql",
        "intents": ["raw_firm_exposure"],
        "data_kinds": ["raw_firm_exposure"],
        "data_fields": {
          "metric": "severity_weighted",
          "formula_version": "raw_severity_v0",
          "scope": "raw_fda_recalling_firm"
        },
        "top_items": [
          {
            "rank": 1,
            "recalling_firm": "King Bio Inc.",
            "total_recalls": 465,
            "class_i_recalls": 465,
            "class_ii_recalls": 0,
            "class_iii_recalls": 0,
            "exposure_score": 1395
          }
        ],
        "summary_contains_any": ["severity-weighted exposure score", "not a safety verdict", "raw FDA"],
        "no_ilike": true
      }
    },
    {
      "id": "exposure-filtered-california-preserves-state",
      "kind": "ask",
      "question": "Which firms in California have the most FDA drug recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_by", "raw_firm_exposure"],
        "data_kinds": ["distribution", "raw_firm_exposure"],
        "filters_include": [
          {"column": "state", "op": "eq", "values": ["CA"]}
        ],
        "top_items": [
          {"firm_equals": "Herbal Doctor Remedies", "recall_count_equals": 113}
        ],
        "no_ilike": true
      }
    },
    {
      "id": "exposure-filtered-class-i-preserves-class",
      "kind": "ask",
      "question": "Rank firms by severity-weighted Class I recalls.",
      "assert": {
        "route": "sql",
        "intents": ["count_by", "raw_firm_exposure"],
        "data_kinds": ["distribution", "raw_firm_exposure"],
        "filters_include": [
          {"column": "classification", "op": "eq", "values": ["Class I"]}
        ],
        "top_items": [
          {"firm_equals": "King Bio Inc.", "recall_count_equals": 465}
        ],
        "no_ilike": true
      }
    },
    {
      "id": "fuzzy-sterility-routing",
      "kind": "ask",
      "question": "Show me a few sterility-related recalls.",
      "assert": {
        "route": "semantic",
        "intents": ["sample"],
        "data_kinds": ["retrieval"],
        "no_ilike": true,
        "semantic_query_contains_any": ["sterility", "sterile"]
      }
    },
    {
      "id": "fuzzy-superpotent-routing",
      "kind": "ask",
      "question": "Show recalls where pills were too strong.",
      "assert": {
        "route": "semantic",
        "intents": ["sample"],
        "data_kinds": ["retrieval"],
        "no_ilike": true,
        "semantic_query_contains_any": ["strong", "superpotent", "potent"]
      }
    },
    {
      "id": "taxonomy-sterility-exact-count",
      "kind": "ask",
      "question": "How many sterility recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_total"],
        "data_kinds": ["scalar"],
        "no_ilike": true,
        "value_equals": 6308
      }
    },
    {
      "id": "taxonomy-reason-breakdown",
      "kind": "ask",
      "question": "What are the most common recall reason categories?",
      "assert": {
        "route": "sql",
        "intents": ["count_by_taxonomy"],
        "data_kinds": ["distribution"],
        "no_ilike": true,
        "top_items": [
          {"value": "Sterility assurance", "node_id": "sterility_assurance", "count": 6308}
        ]
      }
    },
    {
      "id": "firm-aidapak-top-reasons-and-products",
      "kind": "ask",
      "question": "Aidapak Services, LLC 帮我看一下这家公司前十最多召回的原因是什么，以及他们旗下的哪些产品召回最多？\n\n请帮我把他们旗下前十最多召回的产品，以及前十最多召回的原因，分别列为两个表。",
      "assert": {
        "route": "sql",
        "intents": ["multi_count_by"],
        "data_kinds": ["multi_section"],
        "no_ilike": true,
        "section_count": 2,
        "sections": [
          {
            "id": "top_recall_reason_categories",
            "kind": "distribution",
            "dimension": "recall_reason_category",
            "source": "taxonomy",
            "top_items": [
              {"value": "Labeling error", "node_id": "labeling_error", "count": 538}
            ]
          },
          {
            "id": "top_recalled_products",
            "kind": "distribution",
            "dimension": "product_description",
            "source": "drug_enforcement.product_description",
            "min_items": 10,
            "top_items": [
              {"value_contains": "CILOSTAZOL Tablet, 100 mg", "count": 2}
            ]
          }
        ]
      }
    },
    {
      "id": "taxonomy-cgmp-explanation-zh",
      "kind": "ask",
      "question": "CGMP Deviations Reason for recall 中的一个召回原因有这么一个类别，这到底是什么？在药物领域里面，这是什么意思啊？",
      "assert": {
        "route": "explanation",
        "intents": ["explain_taxonomy_node"],
        "data_kinds": ["taxonomy_explanation"],
        "data_not_kinds": ["distribution"],
        "taxonomy_node_id_equals": "cgmp_deviation",
        "summary_contains_any": ["cgmp", "gmp", "良好生产规范", "生产质量管理规范", "current good manufacturing practice"],
        "no_ilike": true
      }
    },
    {
      "id": "taxonomy-cgmp-count-still-sql",
      "kind": "ask",
      "question": "How many cGMP deviation recalls are there?",
      "assert": {
        "route": "sql",
        "intents": ["count_total"],
        "data_kinds": ["scalar"],
        "taxonomy_node_id_equals": "cgmp_deviation",
        "no_ilike": true
      }
    },
    {
      "id": "taxonomy-sterility-by-firm",
      "kind": "ask",
      "question": "Which firms had the most sterility recalls?",
      "assert": {
        "route": "sql",
        "intents": ["count_by"],
        "data_kinds": ["distribution"],
        "no_ilike": true,
        "top_items": [
          {"value": "The Compounding Pharmacy of America", "count": 383}
        ]
      }
    },
    {
      "id": "control-empty-sample-guard",
      "kind": "ask",
      "question": "Show me recalls.",
      "assert": {
        "route": "ambiguous",
        "data_kinds": ["clarification"],
        "spec_empty": true
      }
    },
    {
      "id": "retrieval-glass-particles",
      "kind": "retrieval_recall",
      "query": "glass particles in drug vials",
      "field": "both",
      "k": 10,
      "retrieval_mode": "hybrid",
      "expected_recall_numbers": ["D-0580-2026", "D-0412-2025", "D-0416-2025"],
      "min_recall_at_k": 0.34
    }
  ]
}
