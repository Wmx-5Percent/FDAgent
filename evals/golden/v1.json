{"description": "FDAgent v1 golden eval set for /ask routing and retrieval recall@k.",
  "version": "v1",
  "case_metadata_contract": {
    "required_case_fields": [
      "id",
      "kind",
      "suite",
      "risk",
      "requires_llm",
      "requires_embedding",
      "requires_db",
      "assert"
    ],
    "suite": "string or non-empty list of strings defined in top-level suites",
    "risk": "stable risk area protected by the case",
    "assert": "executable assertion object; input fields such as question/query/k stay at case top level",
    "optional_case_fields": [
      "allow_provider_unavailable_skip"
    ],
    "allow_provider_unavailable_skip": "optional boolean; only provider-unavailable errors may SKIP when true; deterministic assertion failures must still fail"
  },
  "suites": {
    "core": {
      "description": "Stable PR-blocking /ask, deterministic-helper, and provider-configuration contract cases.",
      "blocking": true,
      "default_command": ".venv/bin/python scripts/run_eval.py --core-pr-gate"
    },
    "rag": {
      "description": "Retrieval, embedding, semantic-routing, and recall@k quality cases.",
      "blocking": false,
      "default_command": ".venv/bin/python scripts/run_eval.py --golden evals/golden/v1.json --suite rag"
    },
    "answer_quality": {
      "description": "Final-answer honesty, caveat, evidence, and no-overclaim checks for future suites.",
      "blocking": false
    },
    "firm_profile": {
      "description": "Future Recall Profile / company-profile behavior checks; contract only for now.",
      "blocking": false
    },
    "regression": {
      "description": "Permanent fixed-bug regression tag; combine with a primary suite tag.",
      "blocking": false
    }
  },
