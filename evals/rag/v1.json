{"description": "FDAgent RAG retrieval benchmark suite v1: fixed queries, recall@k, ranking quality, and provider fallback behavior.",
  "version": "rag-v1",
  "case_metadata_contract": {
    "required_case_fields": [
      "id",
      "kind",
      "suite",
      "risk",
      "requires_llm",
      "requires_embedding",
      "requires_db",
      "assert"
    ],
    "suite": "string or non-empty list of strings defined in top-level suites",
    "risk": "stable risk area protected by the case",
    "assert": "retrieval metric thresholds and expected recall_number evidence"
  },
  "suites": {
    "rag": {
      "description": "Retrieval recall@k, ranking quality, and provider/fallback behavior for hybrid search.",
      "blocking": false,
      "default_command": ".venv/bin/python scripts/run_eval.py --golden evals/rag/v1.json --suite rag"
    },
    "regression": {
      "description": "Permanent fixed-bug or fixed-behavior regression tag.",
      "blocking": false
    }
  },
  "cases": [
    {
      "id": "rag-hybrid-glass-particles",
      "kind": "retrieval_recall",
      "query": "glass particles in drug vials",
      "field": "both",
      "k": 10,
      "suite": [
        "rag",
        "regression"
      ],
      "risk": "retrieval_recall_at_k_hybrid",
      "requires_llm": false,
      "requires_embedding": true,
      "requires_db": true,
      "assert": {
        "expected_recall_numbers": [
          "D-0580-2026",
          "D-0412-2025",
          "D-0416-2025"
        ],
        "min_recall_at_k": 0.34,
        "min_mrr_at_k": 0.1,
        "retrieval_mode": "hybrid"
      }
    },
    {
      "id": "rag-hybrid-sterility",
      "kind": "retrieval_recall",
      "query": "sterility problems sterile contamination compounded drug",
      "field": "both",
      "k": 10,
      "suite": [
        "rag",
        "regression"
      ],
      "risk": "retrieval_recall_at_k_hybrid",
      "requires_llm": false,
      "requires_embedding": true,
      "requires_db": true,
      "assert": {
        "expected_recall_numbers": [
          "D-416-2014",
          "D-324-2016",
          "D-335-2016",
          "D-415-2014",
          "D-308-2016"
        ],
        "min_recall_at_k": 0.4,
        "min_mrr_at_k": 0.1,
        "retrieval_mode": "hybrid"
      }
    },
    {
      "id": "rag-hybrid-superpotent-subpotent",
      "kind": "retrieval_recall",
      "query": "superpotent subpotent assay too strong too weak",
      "field": "both",
      "k": 10,
      "suite": [
        "rag",
        "regression"
      ],
      "risk": "retrieval_recall_at_k_hybrid",
      "requires_llm": false,
      "requires_embedding": true,
      "requires_db": true,
      "assert": {
        "expected_recall_numbers": [
          "D-0081-2018",
          "D-057-2013",
          "D-166-2013",
          "D-0048-2025",
          "D-0119-2021"
        ],
        "min_recall_at_k": 0.4,
        "min_mrr_at_k": 0.1,
        "retrieval_mode": "hybrid"
      }
    },
    {
      "id": "rag-fts-fallback-superpotent-subpotent",
      "kind": "retrieval_recall",
      "query": "superpotent subpotent assay too strong too weak",
      "field": "both",
      "k": 10,
      "suite": [
        "rag",
        "regression"
      ],
      "risk": "retrieval_recall_at_k_fts_fallback",
      "requires_llm": false,
      "requires_embedding": false,
      "requires_db": true,
      "assert": {
        "simulate_embedding_fallback": true,
        "expected_recall_numbers": [
          "D-0081-2018",
          "D-057-2013",
          "D-166-2013",
          "D-0048-2025",
          "D-0119-2021"
        ],
        "min_recall_at_k": 1.0,
        "min_mrr_at_k": 1.0,
        "min_ndcg_at_k": 0.9,
        "min_returned_hits": 10,
        "retrieval_mode": "fts_only",
        "requires_fallback_reason": true,
        "fallback_reason_contains_all": [
          "ProviderMissingKeyError",
          "provider=",
          "model=",
          "operation=embedding"
        ]
      }
    },
    {
      "id": "rag-fts-fallback-contamination-particulate",
      "kind": "retrieval_recall",
      "query": "contamination foreign matter particulate",
      "field": "both",
      "k": 10,
