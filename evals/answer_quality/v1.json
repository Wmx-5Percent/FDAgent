{
  "description": "FDAgent answer-quality and honesty suite v1: final-answer evidence, caveats, degraded retrieval honesty, and pending Recall Profile boundaries.",
  "version": "answer-quality-v1",
  "case_metadata_contract": {
    "required_case_fields": [
      "id",
      "kind",
      "suite",
      "risk",
      "requires_llm",
      "requires_embedding",
      "requires_db",
      "assert"
    ],
    "suite": "string or non-empty list of strings defined in top-level suites",
    "risk": "answer-quality or honesty boundary protected by the case",
    "assert": "deterministic final-answer structure/text/evidence assertions; LLM judge is never the only zero-tolerance assertion"
  },
  "suites": {
    "answer_quality": {
      "description": "Final-answer honesty, caveat, evidence, degraded-retrieval, and no-overclaim checks.",
      "blocking": false,
      "default_command": ".venv/bin/python scripts/run_eval.py --golden evals/answer_quality/v1.json --suite answer_quality"
    },
    "firm_profile": {
      "description": "Future Recall Profile / company-profile answer-boundary checks; expected-future cases are explicit SKIP until issue #43 ships.",
      "blocking": false,
      "default_command": ".venv/bin/python scripts/run_eval.py --golden evals/answer_quality/v1.json --suite firm_profile"
    },
    "regression": {
      "description": "Permanent fixed-bug or fixed-boundary regression tag.",
      "blocking": false
    }
  },
  "cases": [
    {
