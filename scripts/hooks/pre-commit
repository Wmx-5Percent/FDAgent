#!/usr/bin/env bash
# Pre-commit hook: block the commit if PROJECT_INDEX.md is stale.
#
# This file is the version-controlled source of truth. It is activated by a
# symlink at .git/hooks/pre-commit (see scripts/hooks/install.sh), so the logic
# lives in git and cannot drift from an untracked copy.
#
#   Regenerate the index:  .venv/bin/python scripts/gen_index.py
#   Bypass this hook once:  git commit --no-verify
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

# Prefer the project venv; fall back to system python.
if [ -x ".venv/bin/python" ]; then
  py=".venv/bin/python"
else
  py="$(command -v python3 || command -v python || true)"
fi
if [ -z "${py:-}" ]; then
  echo "pre-commit: no python interpreter found; skipping index check." >&2
  exit 0
fi

if ! "$py" scripts/gen_index.py --check; then
  {
    echo ""
    echo "pre-commit: PROJECT_INDEX.md is out of date — commit blocked."
    echo "  fix :  $py scripts/gen_index.py && git add PROJECT_INDEX.md"
    echo "  skip:  git commit --no-verify"
  } >&2
  exit 1
fi
