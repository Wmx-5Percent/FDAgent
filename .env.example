# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).

# Required for the LLM structuring pipeline + embeddings (Phase 1+)
OPENAI_API_KEY=sk-...

# If you use Azure OpenAI instead of OpenAI:
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-06-01

# Optional: raises openFDA rate limits (240/min, 120k/day instead of 1000/day).
# Get one free at https://open.fda.gov/apis/authentication/
# OPENFDA_API_KEY=...

# PostgreSQL connection for the ingester (src/fetch_openfda.py).
# Postgres.app default: local user, no password, db must exist (CREATE DATABASE fda;).
DATABASE_URL=postgresql://localhost:5432/fda
