# Copy to .env and fill in. NEVER commit the real .env (it is git-ignored).

# Chat / structured-output provider. Chat calls use the OpenAI-compatible API shape.
# Use OpenRouter when OpenAI chat quota is unavailable.
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini

# Optional: title generation can use a small non-reasoning model even when LLM_MODEL is a
# reasoning model. Defaults to OpenRouter + openai/gpt-4o-mini when LLM_PROVIDER=openrouter.
TITLE_LLM_MODEL=openai/gpt-4o-mini

# OpenAI-compatible OpenRouter settings.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=FDAgent
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:8000

# Embeddings are a separate provider/model boundary. Existing pgvector rows are
# text-embedding-3-small, 1536 dimensions; keep QUERY embeddings compatible.
# OpenRouter option: routes query embeddings through OPENROUTER_API_KEY without
# re-embedding the corpus. The model slug below is dimension-compatible.
EMBED_PROVIDER=openrouter
EMBED_MODEL=openai/text-embedding-3-small

# Direct OpenAI option, also compatible with existing stored vectors:
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-...

# Backward-compatible aliases still supported:
# OPENAI_MODEL=gpt-4o-mini          # used when LLM_PROVIDER=openai and LLM_MODEL is unset
# OPENAI_EMBED_MODEL=text-embedding-3-small

# If you use Azure OpenAI instead of OpenAI:
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-06-01

# Optional: raises openFDA rate limits (240/min, 120k/day instead of 1000/day).
# Get one free at https://open.fda.gov/apis/authentication/
# OPENFDA_API_KEY=...

# PostgreSQL connection for the ingester (src/fetch_openfda.py).
# Postgres.app default: local user, no password, db must exist (CREATE DATABASE fda;).
DATABASE_URL=postgresql://localhost:5432/fda
